---
---

<section class="section" id="competencia" aria-labelledby="eventos-heading">
  <span class="section-eyebrow">Inscripciones abiertas</span>
  <h2 class="section-title" id="eventos-heading">
    Sumate como <em>participante</em>.
  </h2>
  <p class="section-lead">Dos formas de meterse al ruedo. Cupos limitados.</p>

  <div class="events-grid">

    <!-- Competencia Aeropress -->
    <article class="event-card" id="competencia-card" aria-labelledby="aeropress-title">
      <span class="badge">Competencia</span>
      <h3 id="aeropress-title">Aeropress<em>2026.</em></h3>

      <ul class="event-meta" role="list">
        <li class="m">Dom 24/05</li>
        <li class="m">15:30 hs</li>
        <li class="m">Kokoro</li>
      </ul>

      <div class="event-price">
        <div>
          <p class="ptag">Inscripción</p>
          <p class="pval">$ 20.000</p>
        </div>
        <p class="event-incl" style="text-align:right;">
          Incluye 1 consumición<br />+ 1 medialuna
        </p>
      </div>

      <div class="event-prize">
        <img src="/assets/grano-ganador.png" alt="" aria-hidden="true" />
        <p>
          <strong>Premio · 1er puesto</strong>
          Pase gratuito a la Competencia Regional de Aeropress Salta 2026.
        </p>
      </div>

      <div class="event-actions">
        <a class="btn" href="https://docs.google.com/forms/d/e/1FAIpQLSdgegVQ9XT1bL7CyHcLhikqFaD5hGkTVgR71lhZYRferHnQLw/viewform" target="_blank" rel="noopener noreferrer">Inscribirme</a>
        <a class="btn btn--outline" href="#faq">Reglamento</a>
      </div>

      <img src="/assets/aeropress.png" alt="" aria-hidden="true" class="event-illu" />
    </article>

    <!-- Cata de café -->
    <article class="event-card cata" id="cata" aria-labelledby="cata-title">
      <span class="badge">Experiencia</span>
      <h3 id="cata-title">Cata de <em>Café.</em></h3>

      <ul class="event-meta" role="list">
        <li class="m">Dom 24/05</li>
        <li class="m">17:00 hs</li>
        <li class="m">Cupo limitado</li>
      </ul>

      <div class="event-price">
        <div>
          <p class="ptag">Inscripción</p>
          <p class="pval">$ 15.000</p>
        </div>
        <p class="event-incl" style="text-align:right;">
          8 muestras · 3 orígenes<br />Tostado por <strong>The Batuta</strong>
        </p>
      </div>

      <ul class="coffees-row" role="list">
        <li class="coffee-chip">
          <img src="/assets/bean-brasil.png" alt="Granos de Brasil" />
          <div>
            <p class="origin">Brasil</p>
            <p class="notes">Chocolate · caramelo</p>
          </div>
        </li>
        <li class="coffee-chip">
          <img src="/assets/bean-colombia-1.png" alt="Granos de Colombia" />
          <div>
            <p class="origin">Colombia</p>
            <p class="notes">Panela · cítrica</p>
          </div>
        </li>
        <li class="coffee-chip">
          <img src="/assets/bean-peru-1.png" alt="Granos de Perú" />
          <div>
            <p class="origin">Perú</p>
            <p class="notes">Floral · miel</p>
          </div>
        </li>
        <li class="coffee-chip">
          <img src="/assets/bean-colombia-2.png" alt="Granos de Colombia varietal 2" />
          <div>
            <p class="origin">Colombia</p>
            <p class="notes">Ciruela · cacao</p>
          </div>
        </li>
      </ul>

      <div class="event-actions">
        <a class="btn" href="https://docs.google.com/forms/d/e/1FAIpQLSdgegVQ9XT1bL7CyHcLhikqFaD5hGkTVgR71lhZYRferHnQLw/viewform" target="_blank" rel="noopener noreferrer">Inscribirme</a>
      </div>
    </article>

  </div>
</section>
