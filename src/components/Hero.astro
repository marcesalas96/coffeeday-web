---
---

<div class="hero-frame">
  <section class="paper hero" id="evento" aria-labelledby="hero-heading">
    <p class="hero-edition">Edición 2026 · Salta</p>

    <div class="hero-grid">
      <div class="hero-left">
        <h1 class="hero-title" id="hero-heading">
          <span class="coffee">Coffee</span>
          <span class="day">day.</span>
        </h1>

        <div class="hero-center">
          <dl class="hero-meta">
            <div class="meta-block">
              <dt class="label">Fecha</dt>
              <dd class="value">Dom · 24 <small>de Mayo</small></dd>
            </div>
            <div class="meta-block">
              <dt class="label">Horario</dt>
              <dd class="value">15 → 20 hs</dd>
            </div>
            <div class="meta-block">
              <dt class="label">Lugar</dt>
              <dd class="value">
                Kokoro <small>20 de Febrero 473, Salta</small>
              </dd>
            </div>
            <div class="meta-block">
              <dt class="label">Acceso</dt>
              <dd class="value">
                Libre · 5 hs <small>Inscripción por MD</small>
              </dd>
            </div>
          </dl>

          <p class="hero-tagline">
            Café, música y <u>cultura cafetera</u>.<br />
            Una tarde para tomar, escuchar y competir.
          </p>

          <div class="hero-cta">
            <a class="btn btn--accent" href="#competencia"
              >Inscribirme a la competencia →</a
            >
            <a class="btn btn--outline" href="#crono">Ver cronograma</a>
          </div>
        </div>
      </div>

      <div class="hero-aeropress">
        <img
          src="/assets/aeropress.png"
          alt="Aeropress — herramienta de preparación de café"
        />
      </div>
    </div>

    <!-- Signature mark (decorative) -->
    <span class="hero-sig" aria-hidden="true">V<i>/</i></span>
  </section>
</div>
